# Copy to `.env` in the project root and fill in (`.env` is gitignored).

# --- Semantic Scholar（与 LLM Center 无关）---
# 在 https://www.semanticscholar.org/product/api 申请 API Key，填入下方。
SEMANTIC_SCHOLAR_KEY=
# 生产者仅调用 ``paper/search``，不逐篇 ``paper/{{id}}``（省配额；缺 PDF 的条目由漏斗标为 NO_PDF）。
# HTTPS 证书（与飞书 Webhook 共用逻辑，见 `utils/ssl_context.py`）：若 aiohttp/urllib 报 SSL 错误可设企业 CA 或：
# SEMANTIC_SCHOLAR_INSECURE_SSL=1
# HTTPS_INSECURE_SSL=1   # 全局，影响所有出站 HTTPS（仅可信网络）

# --- LLM Center（公司网关，非 Google 官方 Gemini 直连）---
# 个人中心 → 创建个人 Key → 复制 API Key（勿提交到仓库或发给他人）。
MODELBEST_API_KEY=
# 与 TODO 中名称一致时可用：GEMINI_API_KEY=

# 文档「API 地址」：外网根路径 / 内网根路径（二选一，按当前网络环境）。
LLM_CENTER_API_ROOT=https://llm-center.ali.modelbest.cn/llm
# LLM_CENTER_API_ROOT=https://llm-center.ali.modelbest.co/llm

# 一般无需改；仅当平台调用说明中的完整 URL 与默认不一致时再覆盖：
# LLM_CHAT_COMPLETIONS_URL=https://llm-center.ali.modelbest.cn/llm/v1/chat/completions

# 在 LLMCenter 复制「模型 ID」（如 gemini-3.1-pro-preview）。
LLM_MODEL_ID=gemini-3.1-pro-preview

# --- 日预算熔断（PRD 3.3；utils/budget_controller.py）---
# 自然日累计费用（按下方单价折算）达到或超过该值时，check_budget 抛 BudgetLimitExceeded。
# BUDGET_DAILY_LIMIT_CNY=33
# 公司模型默认单价（元/1K tokens）；定价变更时可覆盖：
# LLM_PRICE_INPUT_CNY_PER_1K=0.0040
# LLM_PRICE_OUTPUT_CNY_PER_1K=0.0240
# LLM_PRICE_CACHE_CNY_PER_1K=0.0040

# consumer_pipeline：单次补全上限（粗估预算与 API 共用；默认 8192）
# LLM_MAX_COMPLETION_TOKENS=8192

# excel_exporter：导出 Excel 时 ai_score 下限（含），默认 3（PRD 3.4）
# EXCEL_EXPORT_MIN_SCORE=3

# consumer_pipeline / closed_loop：目标并发（``core/closed_loop.py`` 未传 CLI 时默认读此变量，代码内缺省为 8；仅跑 consumer CLI 时缺省为 1）
# CONSUMER_CONCURRENCY=8
# 硬上限（1–512，默认 64）。注意：并发过高常更慢（SQLite 锁、LLM/下载限流），建议先 16～48 压测再升
# CONSUMER_MAX_CONCURRENCY=64
# 每轮最多拉取的 PENDING 数（closed_loop）
# CLOSED_LOOP_BATCH_SIZE=32
# closed_loop 最大轮数（默认 1000000；``0`` 或负数=不限制轮数，仍会在预算/PENDING 不降/PENDING=0 时停止）
# CLOSED_LOOP_MAX_ROUNDS=0

# main_cron：每日 01:00 消费唤醒每轮最多拉取多少条 PENDING（未设置时 main_cron 默认 64；旧默认 512）
# CRON_CONSUMER_LIMIT=64
# 消费唤醒：与 closed_loop 相同多轮至空/熔断；本值为「每轮」单批上限（非全日总篇数），详见 main_cron 说明。
# 消费唤醒飞书：预算熔断且仍有 PENDING 时发提醒；队列为空时由 closed_loop 导出 Excel 并通知（需 FEISHU_WEBHOOK_URL）
# CRON_CONSUMER_FEISHU=1

# --- 飞书 Webhook ---
# 飞书开放平台 / 群机器人：创建后得到 Webhook 地址，填入。
FEISHU_WEBHOOK_URL=
# 若 Python 报 SSL 自签/证书链错误（公司代理解密等）：任选其一
# FEISHU_WEBHOOK_CA_BUNDLE=/path/to/corp-proxy-ca.pem
# FEISHU_WEBHOOK_INSECURE_SSL=1   # 仅可信任网络，跳过 TLS 校验（不推荐长期使用）
