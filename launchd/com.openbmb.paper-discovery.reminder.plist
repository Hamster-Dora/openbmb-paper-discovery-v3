<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.openbmb.paper-discovery.reminder</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/zhangzhixian/Desktop/openbmb-paper-discovery-v3/venv/bin/python</string>
        <string>/Users/zhangzhixian/Desktop/openbmb-paper-discovery-v3/main_cron.py</string>
